# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/research_navigator

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI API key (required for all AI features)
OPENAI_API_KEY=sk-...

# Optional: custom OpenAI-compatible base URL
# Use this to point at Azure OpenAI, a local proxy, or any OpenAI-compatible API
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── OpenAlex ──────────────────────────────────────────────────────────────────
# Providing your email moves requests into OpenAlex's "polite pool" (faster, more reliable)
# OPENALEX_EMAIL=your@email.com

# ─── Server ────────────────────────────────────────────────────────────────────
# API server port (default: 8080)
# PORT=8080
